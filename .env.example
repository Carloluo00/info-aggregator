FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token
# Optional if your bot enables signature verification
FEISHU_BOT_SECRET=

# Polling interval in seconds
POLL_INTERVAL_SECONDS=300

# Legacy migration input: only used on first startup when sources table is empty
RSS_URLS=https://example.com/feed,https://another.example.com/rss.xml

# SQLite path
SQLITE_PATH=data/app.db

# Push throttling
MAX_PUSH_PER_CYCLE=5
SUMMARY_WHEN_EXCEED=true
